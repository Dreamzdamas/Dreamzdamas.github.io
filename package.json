{
  "name": "dreamz-portfolio",
  "version": "1.0.0",
  "description": "Dreamz Videography Portfolio with Authentication Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "tunnel": "ssh -R 80:127.0.0.1:3000 nokey@localhost.run -o StrictHostKeyChecking=accept-new",
    "serve": "concurrently \"npm run start\" \"npm run tunnel\""
  },
  "dependencies": {
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "localtunnel": "^2.0.2",
    "nodemon": "^3.0.1"
  },
  "author": "Dreamz Visuals",
  "license": "ISC"
}
